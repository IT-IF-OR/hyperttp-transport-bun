{
  "name": "@hyperttp/transport-bun",
  "version": "0.2.4",
  "description": "High-performance HTTP transport for Bun with native fetch optimizations",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "http",
    "transport",
    "high-performance",
    "fetch",
    "bun",
    "hyperttp"
  ],
  "author": "dirold2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IT-IF-OR/hyperttp-transport-bun.git"
  },
  "peerDependencies": {
    "@hyperttp/types": "^0.2.5",
    "hcacher": "^0.1.0"
  },
  "devDependencies": {
    "@dirold2/dev-tools": "^1.1.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "chalk": "^5.6.2",
    "dotenv-cli": "^11.0.0",
    "jiti": "^2.7.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "scripts": {
    "build": "tsc && d-build",
    "dist": "d-dist",
    "deploy": "npm run build && npm run dist",
    "publish": "d-publish",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt src",
    "format:check": "oxfmt src --check",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dev": "tsx src/index.ts"
  }
}
